# ============================================
# AnnSight 数据全流程管理系统 - 环境配置示例
# ============================================

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/annsight

# --------------------------------------------
# 服务器配置
# --------------------------------------------
PORT=3000
NODE_ENV=development

# --------------------------------------------
# JWT 配置
# --------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# --------------------------------------------
# 阿里云 OSS 配置
# --------------------------------------------
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_BUCKET=annsight-data

# --------------------------------------------
# 下载器配置
# --------------------------------------------
DOWNLOAD_TEMP_DIR=/tmp/annsight-downloads
UPLOAD_TEMP_DIR=/tmp/annsight-uploads

# --------------------------------------------
# Whisper 配置（语音转文字）
# --------------------------------------------
OPENCLAW_WHISPER_URL=http://localhost:8000/v1/audio/transcriptions
OPENCLAW_WHISPER_TOKEN=your-whisper-token

# --------------------------------------------
# OCR 配置
# --------------------------------------------
OCR_ENGINE=tesseract

# --------------------------------------------
# Playwright 配置
# --------------------------------------------
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# --------------------------------------------
# ETL 配置
# --------------------------------------------
CONFIDENCE_THRESHOLD=0.8
COOLING_HOURS=24
LSH_THRESHOLD=0.85

# --------------------------------------------
# Dify 配置
# --------------------------------------------
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=your-dify-api-key
