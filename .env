# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=annsight_data
DB_USER=postgres
DB_PASSWORD=postgres

# 测试数据库配置
TEST_DB_NAME=annsight_data_test

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT 配置
JWT_SECRET=annsight-test-jwt-secret-key-2026
JWT_EXPIRES_IN=24h

# 服务器配置
PORT=3000
NODE_ENV=development

# AI 置信度阈值
CONFIDENCE_THRESHOLD=0.8

# 冷却期（小时）
COOLING_HOURS=24

# Dify API 配置
DIFY_API_BASE_URL=http://localhost:5001
DIFY_API_KEY=app-test-key

# 阿里云 OSS 配置
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY=test-access-key
ALIYUN_OSS_SECRET_KEY=test-secret-key
ALIYUN_OSS_BUCKET=annsight-test-data

# 智谱 AI API 配置（用于数据优化）
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL=glm-4
