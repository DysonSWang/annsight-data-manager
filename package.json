{
  "name": "annsight-data-manager",
  "version": "1.0.0",
  "description": "AnnSight 数据全流程管理系统 - AI 优先 + 人工抽检模式",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "NODE_ENV=test jest --coverage --detectOpenHandles",
    "test:unit": "NODE_ENV=test jest tests/unit --detectOpenHandles",
    "test:integration": "NODE_ENV=test jest tests/integration --detectOpenHandles",
    "test:e2e": "NODE_ENV=test jest tests/e2e --detectOpenHandles",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:uat": "node tests/uat/test-etl-pipeline-uat.js",
    "test:full-uat": "node tests/uat/test-full-pipeline-uat.js",
    "test:finetuning": "node tests/uat/test-finetuning-workflow-uat.js",
    "db:migrate": "node scripts/migrate.js",
    "db:reset": "NODE_ENV=test node scripts/migrate.js --reset",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.4.3",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonpath": "^1.3.0",
    "jsonwebtoken": "^9.0.3",
    "minhashjs": "^1.0.1",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "playwright": "^1.58.2",
    "supertest": "^6.3.4",
    "testcontainers": "^10.7.1"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "globalSetup": "./tests/setup.js",
    "globalTeardown": "./tests/setup.js",
    "setupFilesAfterEnv": [
      "./tests/setupTests.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(minhashjs)/)"
    ]
  }
}
